// This is your Prisma schema file,
// learn more about in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  PASTOR
  MINISTRY_LEADER
  CONTENT_MANAGER
  FINANCE_MANAGER
  MEMBER
}

model User {
  id                         String    @id @default(uuid())
  email                      String    @unique
  password                   String?
  phoneNumber                String?
  name                       String
  avatar                     String?
  about                      String?
  role                       Role      @default(MEMBER)
  lastLogin                  DateTime  @default(now())
  isVerified                 Boolean   @default(false)
  resetPasswordToken         String?
  resetPasswordExpiresAt     DateTime?
  verificationToken          String?
  verificationTokenExpiresAt DateTime?
  deletedAt                  DateTime?  @db.Timestamptz
  createdAt                  DateTime  @default(now()) @db.Timestamptz
  updatedAt                  DateTime  @updatedAt @db.Timestamptz

  @@index([email])
  @@index([role])
  @@index([deletedAt])
  @@map("users")

  sermons           Sermon[]
  donations         Donation[]
  blogPosts         Blog[]
  prayerRequests    PrayerRequest[]
  podcasts          Podcast[]
  ministries        Ministry[]
  preferences       MemberPreference[]
  auditLogs         AuditLog[]
  notifications     Notification[]
}

model Sermon {
  id           String   @id @default(uuid())
  title        String
  slug         String?  @unique
  description  String?
  date         DateTime @default(now()) @db.Timestamptz
  videoUrl     String?
  audioUrl     String?
  thumbnailUrl String?
  series       String?
  published    Boolean  @default(false)
  views        Int      @default(0)
  preacher     User?    @relation(fields: [preacherId], references: [id])
  preacherId   String?
  deletedAt    DateTime? @db.Timestamptz
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  @@index([published])
  @@index([date])
  @@index([series])
  @@index([slug])
  @@index([deletedAt])
  @@index([preacherId])
  @@index([published, date])
  @@map("sermons")
}

model Event {
  id                      String   @id @default(uuid())
  title                   String
  slug                    String?  @unique
  description             String?
  excerpt                 String?
  date                    DateTime @db.Timestamptz
  endDate                 DateTime? @db.Timestamptz
  location                String?
  venue                   String?
  imageUrl                String?
  category                String?
  capacity                Int?
  status                  String   @default("DRAFT")
  registrationRequired    Boolean  @default(false)
  registrationDeadline    DateTime? @db.Timestamptz
  deletedAt               DateTime? @db.Timestamptz
  createdAt               DateTime @default(now()) @db.Timestamptz
  updatedAt               DateTime @updatedAt @db.Timestamptz

  @@index([date])
  @@index([category])
  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@index([status, date])
  @@map("events")
}

model Gallery {
  id        String   @id @default(uuid())
  caption   String
  imageUrls String[]
  deletedAt DateTime? @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([deletedAt])
  @@map("galleries")
}

model MediaItem {
  id           String   @id @default(uuid())
  title        String?
  description  String?
  type         String   @default("IMAGE")
  url          String
  thumbnailUrl String?
  albumId      String?
  album        GalleryAlbum? @relation(fields: [albumId], references: [id])
  categoryId   String?
  category     MediaCategory? @relation(fields: [categoryId], references: [id])
  uploadedBy   String?
  deletedAt    DateTime? @db.Timestamptz
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  @@index([albumId])
  @@index([categoryId])
  @@index([type])
  @@index([deletedAt])
  @@map("media_items")
}

model GalleryAlbum {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  coverImage  String?
  mediaItems  MediaItem[]
  deletedAt   DateTime? @db.Timestamptz
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([slug])
  @@index([deletedAt])
  @@map("gallery_albums")
}

model MediaCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  mediaItems MediaItem[]
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([slug])
  @@map("media_categories")
}

model Donation {
  id              String   @id @default(uuid())
  amount          Float
  currency        String   @default("MWK")
  category        String   @default("general")
  paymentStatus   String   @default("PENDING")
  transactionId   String?
  donorName       String?
  donorEmail      String?
  isAnonymous     Boolean  @default(false)
  donor           User?    @relation(fields: [donorId], references: [id])
  donorId         String?
  message         String?
  deletedAt       DateTime? @db.Timestamptz
  createdAt       DateTime @default(now()) @db.Timestamptz
  updatedAt       DateTime @updatedAt @db.Timestamptz

  @@index([donorId])
  @@index([category])
  @@index([paymentStatus])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([donorId, createdAt])
  @@map("donations")
}

model DonationCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([slug])
  @@map("donation_categories")
}

model DonationReceipt {
  id            String   @id @default(uuid())
  donationId    String
  receiptNumber String   @unique
  issuedAt      DateTime @default(now()) @db.Timestamptz

  @@index([donationId])
  @@index([receiptNumber])
  @@map("donation_receipts")
}

model Blog {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  excerpt      String?
  content      String?
  status       String   @default("DRAFT")
  thumbnailUrl String?
  author       User?    @relation(fields: [authorId], references: [id])
  authorId     String?
  categoryId   String?
  category     BlogCategory? @relation(fields: [categoryId], references: [id])
  published    Boolean  @default(false)
  publishedAt  DateTime? @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  @@index([published])
  @@index([slug])
  @@index([publishedAt])
  @@index([status])
  @@index([categoryId])
  @@index([deletedAt])
  @@index([authorId])
  @@index([published, publishedAt])
  @@map("blogs")
}

model BlogCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String?
  blogs       Blog[]
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([slug])
  @@map("blog_categories")
}

model BlogTag {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([slug])
  @@map("blog_tags")
}

model PrayerRequest {
  id          String   @id @default(uuid())
  title       String?
  request     String
  category    String?
  status      String   @default("PENDING")
  isAnonymous Boolean  @default(false)
  isPublic    Boolean  @default(false)
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  deletedAt   DateTime? @db.Timestamptz
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime? @updatedAt @db.Timestamptz

  @@index([userId])
  @@index([status])
  @@index([category])
  @@index([isPublic])
  @@index([deletedAt])
  @@index([isPublic, status])
  @@map("prayer_requests")
}

model Podcast {
  id           String   @id @default(uuid())
  title        String
  description  String?
  audioUrl     String?
  videoUrl     String?
  thumbnailUrl String?
  duration     Int?
  speaker      User?    @relation(fields: [speakerId], references: [id])
  speakerId    String?
  published    Boolean  @default(false)
  publishedAt  DateTime? @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  @@index([published])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("podcasts")
}

model Ministry {
  id                String   @id @default(uuid())
  name              String
  slug              String?  @unique
  description       String?
  imageUrl          String?
  category          String?
  status            String   @default("ACTIVE")
  meetingSchedule   String?
  contactEmail      String?
  contactPhone      String?
  volunteerRequired Boolean  @default(false)
  leader            User?    @relation(fields: [leaderId], references: [id])
  leaderId          String?
  deletedAt         DateTime? @db.Timestamptz
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  @@index([deletedAt])
  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([leaderId])
  @@index([status, category])
  @@map("ministries")
}

model Course {
  id          String    @id @default(uuid())
  title       String
  slug        String    @unique
  description String?
  category    String?   // Learning track/level, e.g. "Beginners", "Ministers"
  imageUrl    String?
  published   Boolean   @default(false)
  lessons     Lesson[]
  deletedAt   DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  @@index([deletedAt])
  @@index([slug])
  @@index([category])
  @@index([published])
  @@map("courses")
}

model Lesson {
  id          String    @id @default(uuid())
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId    String
  title       String
  description String?
  videoUrl    String?
  order       Int       @default(0)
  published   Boolean   @default(true)
  deletedAt   DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  @@index([courseId])
  @@index([deletedAt])
  @@index([courseId, order])
  @@map("lessons")
}

model MemberPreference {
  id                          String   @id @default(uuid())
  userId                      String   @unique
  user                        User     @relation(fields: [userId], references: [id])
  emailNotifications          Boolean  @default(true)
  smsNotifications            Boolean  @default(false)
  newsletterSubscription      Boolean  @default(true)
  showProfile                 Boolean  @default(true)
  showEmail                   Boolean  @default(false)
  showPhone                   Boolean  @default(false)
  notifyEvents                Boolean  @default(true)
  notifySermons               Boolean  @default(true)
  notifyPrayers               Boolean  @default(true)
  notifyDonations             Boolean  @default(true)
  notifyBlogs                 Boolean  @default(true)
  notifyAnnouncements         Boolean  @default(true)
  createdAt                   DateTime @default(now()) @db.Timestamptz
  updatedAt                   DateTime @updatedAt @db.Timestamptz

  @@index([userId])
  @@map("member_preferences")
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String
  actor     User     @relation(fields: [actorId], references: [id])
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([actorId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}

enum NotificationType {
  SYSTEM
  EVENT
  SERMON
  PRAYER
  DONATION
  BLOG
  ANNOUNCEMENT
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

model Notification {
  id        String               @id @default(uuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      NotificationType
  channel   NotificationChannel
  read      Boolean              @default(false)
  metadata  Json?
  createdAt DateTime             @default(now()) @db.Timestamptz

  @@index([userId])
  @@index([read])
  @@index([type])
  @@index([createdAt])
  @@index([userId, read])
  @@map("notifications")
}

model NotificationTemplate {
  id          String   @id @default(uuid())
  name        String
  type        NotificationType
  subject     String
  body        String
  variables   String[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @db.Timestamptz
  updatedAt   DateTime @updatedAt @db.Timestamptz

  @@index([type])
  @@index([active])
  @@map("notification_templates")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  deletedAt DateTime? @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([read])
  @@index([deletedAt])
  @@map("contact_messages")
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  active    Boolean  @default(true)
  deletedAt DateTime? @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([active])
  @@index([deletedAt])
  @@map("newsletter_subscribers")
}
