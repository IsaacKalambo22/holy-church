// This is your Prisma schema file,
// learn more about in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

model User {
  id                         String    @id @default(uuid())
  email                      String    @unique
  password                   String?
  phoneNumber                String?
  name                       String
  avatar                     String?
  about                      String?
  role                       Role      @default(MEMBER)
  lastLogin                  DateTime  @default(now())
  isVerified                 Boolean   @default(false)
  resetPasswordToken         String?
  resetPasswordExpiresAt     DateTime?
  verificationToken          String?
  verificationTokenExpiresAt DateTime?
  deletedAt                  DateTime?  @db.Timestamptz
  createdAt                  DateTime  @default(now()) @db.Timestamptz
  updatedAt                  DateTime  @updatedAt @db.Timestamptz

  @@index([email])
  @@index([role])
  @@index([deletedAt])
  @@map("users")

  sermons        Sermon[]
  donations      Donation[]
  blogPosts      Blog[]
  prayerRequests PrayerRequest[]
  podcasts       Podcast[]
  ministries     Ministry[]
}

model Sermon {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  description  String?
  date         DateTime @default(now()) @db.Timestamptz
  videoUrl     String?
  audioUrl     String?
  thumbnailUrl String?
  series       String?
  published    Boolean  @default(false)
  views        Int      @default(0)
  preacher     User?    @relation(fields: [preacherId], references: [id])
  preacherId   String?
  deletedAt    DateTime? @db.Timestamptz
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  @@index([published])
  @@index([date])
  @@index([series])
  @@index([slug])
  @@index([deletedAt])
  @@map("sermons")
}

model Event {
  id                      String   @id @default(uuid())
  title                   String
  slug                    String   @unique
  description             String?
  excerpt                 String?
  date                    DateTime @db.Timestamptz
  endDate                 DateTime? @db.Timestamptz
  location                String?
  venue                   String?
  imageUrl                String?
  category                String?
  capacity                Int?
  status                  String   @default("DRAFT")
  registrationRequired    Boolean  @default(false)
  registrationDeadline    DateTime? @db.Timestamptz
  deletedAt               DateTime? @db.Timestamptz
  createdAt               DateTime @default(now()) @db.Timestamptz
  updatedAt               DateTime @updatedAt @db.Timestamptz

  @@index([date])
  @@index([category])
  @@index([slug])
  @@index([status])
  @@index([deletedAt])
  @@map("events")
}

model Gallery {
  id        String   @id @default(uuid())
  caption   String
  imageUrls String[]
  deletedAt DateTime? @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@index([deletedAt])
  @@map("galleries")
}

model Donation {
  id        String   @id @default(uuid())
  amount    Float?
  fund      String   @default("general")
  donor     User?    @relation(fields: [donorId], references: [id])
  donorId   String?
  message   String?
  deletedAt DateTime? @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([donorId])
  @@index([fund])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("donations")
}

model Blog {
  id           String   @id @default(uuid())
  title        String
  content      String?
  slug         String   @unique
  author       User?    @relation(fields: [authorId], references: [id])
  authorId     String?
  thumbnailUrl String?
  published    Boolean  @default(false)
  publishedAt  DateTime? @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  @@index([published])
  @@index([slug])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("blogs")
}

model PrayerRequest {
  id          String   @id @default(uuid())
  request     String?
  isAnonymous Boolean  @default(false)
  status      String   @default("PENDING")
  user        User?    @relation(fields: [userId], references: [id])
  userId      String?
  deletedAt   DateTime? @db.Timestamptz
  createdAt   DateTime @default(now()) @db.Timestamptz

  @@index([userId])
  @@index([status])
  @@index([deletedAt])
  @@map("prayer_requests")
}

model Podcast {
  id           String   @id @default(uuid())
  title        String
  description  String?
  audioUrl     String?
  videoUrl     String?
  thumbnailUrl String?
  duration     Int?
  speaker      User?    @relation(fields: [speakerId], references: [id])
  speakerId    String?
  published    Boolean  @default(false)
  publishedAt  DateTime? @db.Timestamptz
  deletedAt    DateTime? @db.Timestamptz
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  @@index([published])
  @@index([publishedAt])
  @@index([deletedAt])
  @@map("podcasts")
}

model Ministry {
  id                String   @id @default(uuid())
  name              String
  slug              String   @unique
  description       String?
  imageUrl          String?
  category          String?
  status            String   @default("ACTIVE")
  meetingSchedule   String?
  contactEmail      String?
  contactPhone      String?
  volunteerRequired Boolean  @default(false)
  leader            User?    @relation(fields: [leaderId], references: [id])
  leaderId          String?
  deletedAt         DateTime? @db.Timestamptz
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  @@index([deletedAt])
  @@index([slug])
  @@index([category])
  @@index([status])
  @@map("ministries")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  subject   String?
  message   String
  read      Boolean  @default(false)
  deletedAt DateTime? @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([read])
  @@index([deletedAt])
  @@map("contact_messages")
}

model NewsletterSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  active    Boolean  @default(true)
  deletedAt DateTime? @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz

  @@index([active])
  @@index([deletedAt])
  @@map("newsletter_subscribers")
}
