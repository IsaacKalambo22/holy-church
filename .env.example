# Copy to .env.local for local dev, and set the same keys in your host
# (e.g. Vercel → Settings → Environment Variables) for deployments.
# The app validates these on startup (src/lib/env.ts) and will fail the
# build/boot if a REQUIRED one is missing.

# ── Required ──────────────────────────────────────────────────────────
# Postgres connection. On Neon, use the POOLED endpoint (host contains
# "-pooler") for serverless/Vercel reliability.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Secret used to sign session JWTs. Use a long, random value in production.
JWT_SECRET="change-me-to-a-long-random-string"

# Supabase (public — exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# ── Recommended ───────────────────────────────────────────────────────
# Public site URL — used for SEO canonicals, sitemap, and password-reset links.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase storage bucket (defaults to "holy-church" if omitted)
BUCKET_NAME="holy-church"
# Optional but recommended for server-side uploads from Next.js API routes
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── Optional (password-reset / notification emails via SMTP) ───────────
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@holychurch.mw"
